# Public address of the server that friends will connect to.
# For the VPS from your friend this can be 87.76.4.203.
PUBLIC_HOST=87.76.4.203
PUBLIC_IP=87.76.4.203

# Backend is exposed as http://PUBLIC_HOST:BACKEND_PORT.
BACKEND_PORT=18081

# PostgreSQL.
POSTGRES_DB=voistra
POSTGRES_USER=voistra
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD

# Keep true for single-server Docker Compose deploys.
# For Kubernetes or multiple backend replicas, run migrations as a separate job.
DB_MIGRATIONS_RUN=true

# JWT secrets must be long random strings.
JWT_ACCESS_SECRET=CHANGE_ME_LONG_RANDOM_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM_REFRESH_SECRET

# TURN credentials used by WebRTC voice and screen share.
TURN_USERNAME=voistra
TURN_PASSWORD=CHANGE_ME_STRONG_TURN_PASSWORD
TURN_PORT=3478
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
