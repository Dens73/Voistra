{
  "name": "@diplom/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "create:db": "node scripts/create-db.mjs",
    "dev": "npm run build && node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typeorm": "typeorm",
    "migration:run": "npm run build && typeorm migration:run -d dist/database/data-source.js",
    "migration:revert": "npm run build && typeorm migration:revert -d dist/database/data-source.js",
    "migration:show": "npm run build && typeorm migration:show -d dist/database/data-source.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.1",
    "@nestjs/platform-socket.io": "^11.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.1",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "sql.js": "^1.13.0",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/passport-jwt": "^4.0.1",
    "typescript": "^5.7.3"
  }
}
