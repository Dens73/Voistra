{
  "name": "voistra-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Voistra desktop voice workspace",
  "author": "Voistra Team",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron:build\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/main.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/copy-server-dist.cjs && node scripts/copy-server-runtime-deps.cjs",
    "start": "electron dist-electron/main.js",
    "assets:icons": "node scripts/generate-icons.cjs",
    "dist": "node scripts/build-electron-dist.cjs --dir",
    "dist:win": "node scripts/build-electron-dist.cjs --win nsis"
  },
  "dependencies": {
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "35.0.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.voistra.desktop",
    "productName": "Voistra",
    "asar": true,
    "directories": {
      "output": "../../release/voistra"
    },
    "electronLanguages": [
      "en-US",
      "ru"
    ],
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-electron/server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".runtime/server-node_modules",
        "to": "node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public/voistra-mark.svg",
        "to": "public/voistra-mark.svg"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build-assets/voistra-icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "build-assets/voistra-icon.ico",
      "uninstallerIcon": "build-assets/voistra-icon.ico",
      "installerHeaderIcon": "build-assets/voistra-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
